    <!-- Zoom Modal -->
    <div id="zoomModal">
      <img id="zoomImage" src="" alt="">
      <div class="zoom-caption" id="zoomCaption"></div>
      <button class="close-btn" style="position: absolute; top: 20px; right: 20px; color: white; font-size: 30px;" onclick="closeZoom()">&times;</button>
    </div>

    <!-- Toast Notification -->
    <div class="toast" id="toast"></div>

    <!-- Loading Spinner (hidden by default) -->
    <div id="loadingSpinner" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 4000;">
      <div class="spinner"></div>
    </div>
  </div>

  <!-- Install PWA Button (shown when not installed) -->
  <div id="installPWA" style="display: none; position: fixed; bottom: 100px; left: 20px; right: 20px; background: var(--primary); color: white; padding: 15px; border-radius: 30px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.3); z-index: 2000; cursor: pointer;" onclick="installPWA()">
    <i class="fas fa-download"></i> <span data-hi="ऐप इंस्टॉल करें" data-en="Install App">ऐप इंस्टॉल करें</span>
  </div>

  <script>
    // ==================== LANGUAGE SUPPORT ====================
    let currentLanguage = 'hi'; // Default Hindi

    function setLanguage(lang) {
      currentLanguage = lang;
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.remove('active');
        if (btn.textContent.includes(lang === 'hi' ? 'हिंदी' : 'ENG')) {
          btn.classList.add('active');
        }
      });

      // Update all translatable elements
      document.querySelectorAll('[data-hi][data-en]').forEach(el => {
        if (el.tagName === 'OPTION') {
          el.textContent = el.getAttribute(`data-${lang}`);
        } else if (el.classList.contains('tab-label')) {
          el.textContent = el.getAttribute(`data-${lang}`);
        } else {
          el.textContent = el.getAttribute(`data-${lang}`);
        }
      });

      // Update app title
      document.getElementById('appTitle').textContent = lang === 'hi' ? 'खाता मित्र प्रो' : 'Khata Mitra Pro';
      
      // Update placeholders
      document.querySelectorAll('input[placeholder]').forEach(input => {
        const placeholder = input.getAttribute(`data-${lang}-placeholder`);
        if (placeholder) {
          input.placeholder = placeholder;
        }
      });
    }

    // ==================== STATE MANAGEMENT ====================
    let appState = {
      customers: [],
      transactions: [],
      photos: [], // Store photos with transaction IDs
      settings: {
        darkMode: false,
        language: 'hi',
        autoReminder: false
      }
    };

    // Load data from localStorage
    function loadData() {
      const saved = localStorage.getItem('khataMitraPro');
      if (saved) {
        try {
          appState = JSON.parse(saved);
        } catch (e) {
          console.error('Error loading data', e);
        }
      }
      
      // Initialize with demo data if empty
      if (appState.customers.length === 0) {
        initDemoData();
      }
      
      // Set language
      if (appState.settings.language) {
        setLanguage(appState.settings.language);
      }
      
      updateUI();
    }

    // Save data to localStorage
    function saveData() {
      localStorage.setItem('khataMitraPro', JSON.stringify(appState));
    }

    // Demo data for testing
    function initDemoData() {
      appState.customers = [
        { id: '1', name: 'राहुल कुमार', phone: '9876543210', address: 'दिल्ली', balance: 500 },
        { id: '2', name: 'सीता शर्मा', phone: '8765432109', address: 'नोएडा', balance: -200 },
        { id: '3', name: 'मोहन सिंह', phone: '7654321098', address: 'गुड़गांव', balance: 1000 }
      ];
      
      appState.transactions = [
        { id: 't1', customerId: '1', type: 'udhar', amount: 500, note: 'पिज्जा के लिए', date: '2024-03-15', mode: 'cash' },
        { id: 't2', customerId: '2', type: 'jama', amount: 200, note: 'चाय के पैसे', date: '2024-03-16', mode: 'upi' },
        { id: 't3', customerId: '3', type: 'udhar', amount: 1000, note: 'किराने का सामान', date: '2024-03-17', mode: 'bank' }
      ];
      
      saveData();
    }

    // ==================== UI UPDATE FUNCTIONS ====================
    function updateUI() {
      updateDashboard();
      updateCustomerList();
      updateRecentTransactions();
      updateAllTransactions();
      updateReports();
    }

    function updateDashboard() {
      document.getElementById('totalCustomers').textContent = appState.customers.length;
      
      let totalUdhar = 0, totalJama = 0;
      appState.customers.forEach(c => {
        if (c.balance > 0) totalUdhar += c.balance;
        else totalJama += Math.abs(c.balance);
      });
      
      document.getElementById('totalUdhar').textContent = '₹' + totalUdhar;
      document.getElementById('totalJama').textContent = '₹' + totalJama;
      document.getElementById('netBalance').textContent = '₹' + (totalUdhar - totalJama);
    }

    function updateCustomerList() {
      const list = document.getElementById('customerList');
      const searchTerm = document.getElementById('customerSearch')?.value.toLowerCase() || '';
      
      const filtered = appState.customers.filter(c => 
        c.name.toLowerCase().includes(searchTerm) || 
        (c.phone && c.phone.includes(searchTerm))
      );
      
      if (filtered.length === 0) {
        list.innerHTML = `
          <div class="empty-state">
            <i class="fas fa-users"></i>
            <p data-hi="कोई ग्राहक नहीं मिला" data-en="No customers found">कोई ग्राहक नहीं मिला</p>
          </div>
        `;
        return;
      }
      
      list.innerHTML = filtered.map(customer => `
        <div class="customer-card" onclick="viewCustomer('${customer.id}')">
          <div class="customer-info">
            <h3>${customer.name}</h3>
            <p>📞 ${customer.phone || (currentLanguage === 'hi' ? 'नंबर नहीं' : 'No number')}</p>
          </div>
          <div class="customer-balance ${customer.balance >= 0 ? 'balance-positive' : 'balance-negative'}">
            ${customer.balance >= 0 ? '₹' + customer.balance : '-₹' + Math.abs(customer.balance)}
          </div>
        </div>
      `).join('');
    }

    function updateRecentTransactions() {
      const recent = document.getElementById('recentTransactions');
      const transactions = [...appState.transactions].reverse().slice(0, 5);
      
      if (transactions.length === 0) {
        recent.innerHTML = `
          <div class="empty-state">
            <i class="fas fa-exchange-alt"></i>
            <p data-hi="कोई लेन-देन नहीं" data-en="No transactions">कोई लेन-देन नहीं</p>
          </div>
        `;
        return;
      }
      
      recent.innerHTML = transactions.map(t => {
        const customer = appState.customers.find(c => c.id === t.customerId);
        const typeText = t.type === 'udhar' 
          ? (currentLanguage === 'hi' ? 'उधार दिया' : 'Gave')
          : (currentLanguage === 'hi' ? 'जमा लिया' : 'Received');
        
        return `
          <div class="transaction-item" onclick="viewCustomer('${t.customerId}')">
            <div class="transaction-info">
              <div class="transaction-icon ${t.type === 'udhar' ? 'icon-udhar' : 'icon-jama'}">
                <i class="fas ${t.type === 'udhar' ? 'fa-arrow-up' : 'fa-arrow-down'}"></i>
              </div>
              <div class="transaction-details">
                <h4>${customer?.name || 'Unknown'}</h4>
                <p>${t.note || (currentLanguage === 'hi' ? 'कोई विवरण नहीं' : 'No description')} • ${formatDate(t.date)}</p>
              </div>
            </div>
            <div class="transaction-amount ${t.type === 'udhar' ? 'balance-negative' : 'balance-positive'}">
              ${t.type === 'udhar' ? '-' : '+'} ₹${t.amount}
            </div>
          </div>
        `;
      }).join('');
    }

    function updateAllTransactions() {
      const container = document.getElementById('allTransactions');
      const searchTerm = document.getElementById('historySearch')?.value.toLowerCase() || '';
      
      let filtered = [...appState.transactions].reverse();
      
      if (searchTerm) {
        filtered = filtered.filter(t => {
          const customer = appState.customers.find(c => c.id === t.customerId);
          return customer?.name.toLowerCase().includes(searchTerm) || 
                 (t.note && t.note.toLowerCase().includes(searchTerm));
        });
      }
      
      if (filtered.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <i class="fas fa-history"></i>
            <p data-hi="कोई लेन-देन नहीं" data-en="No transactions">कोई लेन-देन नहीं</p>
          </div>
        `;
        return;
      }
      
      container.innerHTML = filtered.map(t => {
        const customer = appState.customers.find(c => c.id === t.customerId);
        const typeText = t.type === 'udhar' 
          ? (currentLanguage === 'hi' ? 'उधार' : 'Gave')
          : (currentLanguage === 'hi' ? 'जमा' : 'Received');
        
        return `
          <div class="transaction-item" onclick="viewCustomer('${t.customerId}')">
            <div class="transaction-info">
              <div class="transaction-icon ${t.type === 'udhar' ? 'icon-udhar' : 'icon-jama'}">
                <i class="fas ${t.type === 'udhar' ? 'fa-arrow-up' : 'fa-arrow-down'}"></i>
              </div>
              <div class="transaction-details">
                <h4>${customer?.name || 'Unknown'}</h4>
                <p>${t.note || ''} • ${t.mode || 'cash'} • ${formatDate(t.date)}</p>
              </div>
            </div>
            <div class="transaction-amount ${t.type === 'udhar' ? 'balance-negative' : 'balance-positive'}">
              ${t.type === 'udhar' ? '-' : '+'} ₹${t.amount}
            </div>
          </div>
        `;
      }).join('');
    }

    function updateReports() {
      const month = document.getElementById('reportMonth')?.value || '3';
      const year = document.getElementById('reportYear')?.value || '2024';
      
      const monthlyTransactions = appState.transactions.filter(t => {
        const [y, m] = t.date.split('-');
        return y === year && m === month.padStart(2, '0');
      });
      
      let monthlyUdhar = 0, monthlyJama = 0;
      monthlyTransactions.forEach(t => {
        if (t.type === 'udhar') monthlyUdhar += t.amount;
        else monthlyJama += t.amount;
      });
      
      document.getElementById('monthlyUdhar').textContent = '₹' + monthlyUdhar;
      document.getElementById('monthlyJama').textContent = '₹' + monthlyJama;
      
      // Update chart
      updateChart(monthlyTransactions);
    }

    // Chart instance
    let monthlyChart = null;

    function updateChart(transactions) {
      const ctx = document.getElementById('monthlyChart').getContext('2d');
      
      // Group by date
      const dailyData = {};
      transactions.forEach(t => {
        const day = t.date.split('-')[2];
        if (!dailyData[day]) {
          dailyData[day] = { udhar: 0, jama: 0 };
        }
        if (t.type === 'udhar') dailyData[day].udhar += t.amount;
        else dailyData[day].jama += t.amount;
      });
      
      const days = Object.keys(dailyData).sort((a, b) => parseInt(a) - parseInt(b));
      const udharData = days.map(d => dailyData[d].udhar);
      const jamaData = days.map(d => dailyData[d].jama);
      
      if (monthlyChart) {
        monthlyChart.destroy();
      }
      
      monthlyChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: days.map(d => d + (currentLanguage === 'hi' ? ' तारीख' : '')),
          datasets: [
            {
              label: currentLanguage === 'hi' ? 'उधार दिया' : 'Given',
              data: udharData,
              backgroundColor: '#e53935',
              borderRadius: 8
            },
            {
              label: currentLanguage === 'hi' ? 'जमा लिया' : 'Received',
              data: jamaData,
              backgroundColor: '#2ec4b6',
              borderRadius: 8
            }
          ]
        },
        options: {
          responsive: true,
          plugins: {
            legend: {
              position: 'bottom'
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                callback: value => '₹' + value
              }
            }
          }
        }
      });
    }

    // ==================== MODAL FUNCTIONS ====================
    function openQuickMenu() {
      document.getElementById('quickMenuModal').classList.add('active');
    }

    function openAddModal(type) {
      closeModal('quickMenuModal');
      
      if (type === 'customer') {
        document.getElementById('addCustomerModal').classList.add('active');
      } else if (type === 'udhar' || type === 'jama') {
        const title = document.getElementById('transactionModalTitle');
        title.textContent = type === 'udhar' 
          ? (currentLanguage === 'hi' ? 'उधार दें' : 'Give Money')
          : (currentLanguage === 'hi' ? 'जमा करें' : 'Receive Money');
        
        document.getElementById('saveTransactionBtn').setAttribute('data-type', type);
        
        // Populate customer dropdown
        const select = document.getElementById('transactionCustomer');
        select.innerHTML = '<option value="">' + 
          (currentLanguage === 'hi' ? 'ग्राहक चुनें' : 'Select Customer') + 
          '</option>' + 
          appState.customers.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
        
        // Set today's date
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('transactionDate').value = today;
        
        // Clear photo preview
        document.getElementById('photoPreview').innerHTML = '';
        
        document.getElementById('addTransactionModal').classList.add('active');
      }
    }

    function closeModal(modalId) {
      document.getElementById(modalId).classList.remove('active');
    }

    // ==================== PHOTO FUNCTIONS ====================
    function previewTransactionPhoto(event) {
      const preview = document.getElementById('photoPreview');
      preview.innerHTML = '';
      
      const file = event.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          const img = document.createElement('img');
          img.src = e.target.result;
          img.style.width = '100px';
          img.style.height = '100px';
          img.style.objectFit = 'cover';
          img.style.borderRadius = '10px';
          preview.appendChild(img);
        }
        reader.readAsDataURL(file);
      }
    }

    function savePhoto(transactionId, file, caption) {
      return new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = function(e) {
          const photo = {
            id: Date.now().toString(),
            transactionId: transactionId,
            data: e.target.result,
            caption: caption || '',
            date: new Date().toISOString()
          };
          
          if (!appState.photos) appState.photos = [];
          appState.photos.push(photo);
          resolve(photo);
        }
        reader.readAsDataURL(file);
      });
    }

    function getTransactionPhotos(transactionId) {
      return appState.photos?.filter(p => p.transactionId === transactionId) || [];
    }

    function getCustomerPhotos(customerId) {
      const transactionIds = appState.transactions
        .filter(t => t.customerId === customerId)
        .map(t => t.id);
      
      return appState.photos?.filter(p => transactionIds.includes(p.transactionId)) || [];
    }

    function deletePhoto(photoId) {
      if (appState.photos) {
        appState.photos = appState.photos.filter(p => p.id !== photoId);
        saveData();
        
        // Refresh customer detail if open
        const customerId = document.getElementById('customerDetailModal').getAttribute('data-customer-id');
        if (customerId) {
          viewCustomer(customerId);
        }
        
        showToast(currentLanguage === 'hi' ? 'फोटो हटा दी गई' : 'Photo deleted');
      }
    }

    function openZoom(imageSrc, caption) {
      document.getElementById('zoomImage').src = imageSrc;
      document.getElementById('zoomCaption').textContent = caption || '';
      document.getElementById('zoomModal').classList.add('active');
    }

    function closeZoom() {
      document.getElementById('zoomModal').classList.remove('active');
    }

    // ==================== CRUD OPERATIONS ====================
    function addCustomer() {
      const name = document.getElementById('newCustomerName').value.trim();
      const phone = document.getElementById('newCustomerPhone').value.trim();
      const address = document.getElementById('newCustomerAddress').value.trim();
      
      if (!name) {
        showToast(currentLanguage === 'hi' ? 'नाम दर्ज करें' : 'Enter name', 'error');
        return;
      }
      
      const newCustomer = {
        id: Date.now().toString(),
        name,
        phone,
        address,
        balance: 0,
        createdAt: new Date().toISOString()
      };
      
      appState.customers.push(newCustomer);
      saveData();
      updateUI();
      
      closeModal('addCustomerModal');
      showToast(currentLanguage === 'hi' ? 'ग्राहक जोड़ दिया गया' : 'Customer added');
      
      // Clear form
      document.getElementById('newCustomerName').value = '';
      document.getElementById('newCustomerPhone').value = '';
      document.getElementById('newCustomerAddress').value = '';
    }

    async function saveTransaction() {
      const customerId = document.getElementById('transactionCustomer').value;
      const amount = parseFloat(document.getElementById('transactionAmount').value);
      const note = document.getElementById('transactionNote').value.trim();
      const date = document.getElementById('transactionDate').value;
      const mode = document.getElementById('transactionMode').value;
      const type = document.getElementById('saveTransactionBtn').getAttribute('data-type');
      const photoFile = document.getElementById('transactionPhoto').files[0];
      
      if (!customerId) {
        showToast(currentLanguage === 'hi' ? 'ग्राहक चुनें' : 'Select customer', 'error');
        return;
      }
      
      if (!amount || amount <= 0) {
        showToast(currentLanguage === 'hi' ? 'सही राशि दर्ज करें' : 'Enter valid amount', 'error');
        return;
      }
      
      // Show loading
      document.getElementById('loadingSpinner').style.display = 'block';
      
      const transaction = {
        id: Date.now().toString(),
        customerId,
        type,
        amount,
        note,
        date,
        mode,
        createdAt: new Date().toISOString()
      };
      
      // Update customer balance
      const customer = appState.customers.find(c => c.id === customerId);
      if (type === 'udhar') {
        customer.balance += amount;
      } else {
        customer.balance -= amount;
      }
      
      appState.transactions.push(transaction);
      
      // Save photo if uploaded
      if (photoFile) {
        await savePhoto(transaction.id, photoFile, note);
      }
      
      saveData();
      updateUI();
      
      // Hide loading
      document.getElementById('loadingSpinner').style.display = 'none';
      
      closeModal('addTransactionModal');
      showToast(currentLanguage === 'hi' ? 'लेन-देन सेव हो गया' : 'Transaction saved');
      
      // Clear form
      document.getElementById('transactionAmount').value = '';
      document.getElementById('transactionNote').value = '';
      document.getElementById('transactionPhoto').value = '';
      document.getElementById('photoPreview').innerHTML = '';
    }

    // ==================== CUSTOMER DETAILS ====================
    function viewCustomer(customerId) {
      const customer = appState.customers.find(c => c.id === customerId);
      if (!customer) return;
      
      document.getElementById('detailCustomerName').textContent = customer.name;
      document.getElementById('detailBalance').textContent = '₹' + Math.abs(customer.balance);
      document.getElementById('detailPhone').textContent = customer.phone || '-';
      
      // Show customer photos
      const photos = getCustomerPhotos(customerId);
      const photosContainer = document.getElementById('customerPhotos');
      
      if (photos.length > 0) {
        photosContainer.innerHTML = photos.map(photo => `
          <div class="gallery-item">
            <img src="${photo.data}" onclick="openZoom('${photo.data}', '${photo.caption}')">
            <div class="caption">${photo.caption || ''}</div>
            <div class="delete-photo" onclick="event.stopPropagation(); deletePhoto('${photo.id}')">
              <i class="fas fa-times"></i>
            </div>
          </div>
        `).join('');
      } else {
        photosContainer.innerHTML = `<p style="color: var(--gray); text-align: center; grid-column: span 3;" data-hi="कोई फोटो नहीं" data-en="No photos">कोई फोटो नहीं</p>`;
      }
      
      // Show transactions
      const transactions = appState.transactions
        .filter(t => t.customerId === customerId)
        .reverse();
      
      const container = document.getElementById('customerTransactions');
      
      if (transactions.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <i class="fas fa-exchange-alt"></i>
            <p data-hi="कोई लेन-देन नहीं" data-en="No transactions">कोई लेन-देन नहीं</p>
          </div>
        `;
      } else {
        container.innerHTML = transactions.map(t => {
          const hasPhoto = getTransactionPhotos(t.id).length > 0;
          return `
            <div class="transaction-item">
              <div class="transaction-info">
                <div class="transaction-icon ${t.type === 'udhar' ? 'icon-udhar' : 'icon-jama'}">
                  <i class="fas ${t.type === 'udhar' ? 'fa-arrow-up' : 'fa-arrow-down'}"></i>
                </div>
                <div class="transaction-details">
                  <h4>${t.type === 'udhar' 
                    ? (currentLanguage === 'hi' ? 'उधार दिया' : 'Gave') 
                    : (currentLanguage === 'hi' ? 'जमा लिया' : 'Received')} 
                    ${hasPhoto ? ' 📸' : ''}</h4>
                  <p>${t.note || ''} • ${formatDate(t.date)}</p>
                </div>
              </div>
              <div class="transaction-amount ${t.type === 'udhar' ? 'balance-negative' : 'balance-positive'}">
                ${t.type === 'udhar' ? '-' : '+'} ₹${t.amount}
              </div>
            </div>
          `;
        }).join('');
      }
      
      // Store customer ID for actions
      document.getElementById('customerDetailModal').setAttribute('data-customer-id', customerId);
      document.getElementById('customerDetailModal').classList.add('active');
    }

    // ==================== PDF EXPORT ====================
    function exportCustomerPDF() {
      const customerId = document.getElementById('customerDetailModal').getAttribute('data-customer-id');
      const customer = appState.customers.find(c => c.id === customerId);
      
      if (!customer) return;
      
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF();
      
      // Colors
      const primaryColor = [106, 27, 154]; // #6a1b9a
      const successColor = [46, 196, 182]; // #2ec4b6
      const dangerColor = [229, 57, 53]; // #e53935
      
      // Header
      doc.setFillColor(primaryColor[0], primaryColor[1], primaryColor[2]);
      doc.rect(0, 0, 210, 40, 'F');
      
      doc.setTextColor(255, 255, 255);
      doc.setFontSize(22);
      doc.setFont('helvetica', 'bold');
      doc.text('Khata Statement', 105, 20, { align: 'center' });
      
      // Customer Info
      doc.setTextColor(0, 0, 0);
      doc.setFontSize(16);
      doc.setFont('helvetica', 'bold');
      doc.text('Customer Details', 20, 55);
      
      doc.setFontSize(12);
      doc.setFont('helvetica', 'normal');
      doc.text(`Name: ${customer.name}`, 20, 65);
      doc.text(`Phone: ${customer.phone || 'N/A'}`, 20, 72);
      doc.text(`Address: ${customer.address || 'N/A'}`, 20, 79);
      
      // Balance
      const balanceY = 95;
      doc.setFillColor(customer.balance >= 0 ? dangerColor[0] : successColor[0], 
                      customer.balance >= 0 ? dangerColor[1] : successColor[1], 
                      customer.balance >= 0 ? dangerColor[2] : successColor[2]);
      doc.roundedRect(20, balanceY - 5, 170, 25, 5, 5, 'F');
      
      doc.setTextColor(255, 255, 255);
      doc.setFontSize(14);
      doc.setFont('helvetica', 'bold');
      doc.text(`Current Balance: ₹${Math.abs(customer.balance)} ${customer.balance >= 0 ? '(To Receive)' : '(To Pay)'}`, 105, balanceY + 10, { align: 'center' });
      
      // Transactions Table
      doc.setTextColor(0, 0, 0);
      doc.setFontSize(14);
      doc.setFont('helvetica', 'bold');
      doc.text('Transaction History', 20, 135);
      
      const transactions = appState.transactions
        .filter(t => t.customerId === customerId)
        .sort((a, b) => new Date(b.date) - new Date(a.date));
      
      let y = 150;
      
      // Table Header
      doc.setFillColor(240, 240, 240);
      doc.rect(20, y - 5, 170, 10, 'F');
      
      doc.setFontSize(10);
      doc.setFont('helvetica', 'bold');
      doc.text('Date', 25, y);
      doc.text('Type', 55, y);
      doc.text('Description', 85, y);
      doc.text('Amount', 160, y);
      
      y += 10;
      
      // Table Rows
      doc.setFont('helvetica', 'normal');
      let totalGiven = 0, totalReceived = 0;
      
      transactions.forEach((t, index) => {
        if (y > 270) {
          doc.addPage();
          y = 30;
          
          // Header on new page
          doc.setFillColor(240, 240, 240);
          doc.rect(20, y - 5, 170, 10, 'F');
          
          doc.setFont('helvetica', 'bold');
          doc.text('Date', 25, y);
          doc.text('Type', 55, y);
          doc.text('Description', 85, y);
          doc.text('Amount', 160, y);
          
          y += 10;
          doc.setFont('helvetica', 'normal');
        }
        
        const amount = t.amount;
        if (t.type === 'udhar') {
          totalGiven += amount;
          doc.setTextColor(dangerColor[0], dangerColor[1], dangerColor[2]);
        } else {
          totalReceived += amount;
          doc.setTextColor(successColor[0], successColor[1], successColor[2]);
        }
        
        doc.text(formatDate(t.date), 25, y);
        doc.text(t.type === 'udhar' ? 'Given' : 'Received', 55, y);
        
        // Truncate long description
        let desc = t.note || '-';
        if (desc.length > 20) desc = desc.substring(0, 18) + '...';
        doc.text(desc, 85, y);
        
        doc.text(`₹${amount}`, 170, y, { align: 'right' });
        
        y += 8;
      });
      
      // Summary
      y += 10;
      doc.setDrawColor(200, 200, 200);
      doc.line(20, y, 190, y);
      y += 10;
      
      doc.setFont('helvetica', 'bold');
      doc.setTextColor(0, 0, 0);
      doc.text('Summary:', 20, y);
      y += 8;
      
      doc.setFont('helvetica', 'normal');
      doc.text(`Total Given:`, 20, y);
      doc.setTextColor(dangerColor[0], dangerColor[1], dangerColor[2]);
      doc.text(`₹${totalGiven}`, 100, y);
      
      y += 8;
      doc.setTextColor(0, 0, 0);
      doc.text(`Total Received:`, 20, y);
      doc.setTextColor(successColor[0], successColor[1], successColor[2]);
      doc.text(`₹${totalReceived}`, 100, y);
      
      y += 8;
      doc.setTextColor(0, 0, 0);
      doc.text(`Net Balance:`, 20, y);
      doc.setTextColor(customer.balance >= 0 ? dangerColor[0] : successColor[0], 
                      customer.balance >= 0 ? dangerColor[1] : successColor[1], 
                      customer.balance >= 0 ? dangerColor[2] : successColor[2]);
      doc.setFont('helvetica', 'bold');
      doc.text(`₹${Math.abs(customer.balance)} ${customer.balance >= 0 ? '(To Receive)' : '(To Pay)'}`, 100, y);
      
      // Footer
      const totalPages = doc.internal.getNumberOfPages();
      for (let i = 1; i <= totalPages; i++) {
        doc.setPage(i);
        doc.setFontSize(8);
        doc.setTextColor(150, 150, 150);
        doc.text(`Generated on ${new Date().toLocaleDateString()} - Page ${i} of ${totalPages}`, 105, 290, { align: 'center' });
      }
      
      doc.save(`${customer.name.replace(/\s+/g, '_')}_Khata.pdf`);
      showToast(currentLanguage === 'hi' ? 'PDF डाउनलोड हो रहा है' : 'PDF is downloading');
    }

