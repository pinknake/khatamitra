    }

    // ==================== UTILITY FUNCTIONS ====================
    function formatDate(dateString) {
      if (!dateString) return '';
      const [year, month, day] = dateString.split('-');
      return `${day}/${month}/${year}`;
    }

    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.style.background = type === 'success' ? '#2ec4b6' : '#e53935';
      toast.classList.add('show');
      
      setTimeout(() => {
        toast.classList.remove('show');
      }, 3000);
    }

    function switchTab(tabName) {
      // Update tab buttons
      document.querySelectorAll('.nav-tab').forEach(tab => {
        tab.classList.remove('active');
      });
      event.currentTarget.classList.add('active');
      
      // Show selected tab
      document.querySelectorAll('.tab-pane').forEach(pane => {
        pane.classList.remove('active');
      });
      document.getElementById(tabName).classList.add('active');
      
      if (tabName === 'reports') {
        updateReports();
      }
    }

    function toggleDarkMode() {
      document.body.classList.toggle('dark-mode');
      const icon = document.getElementById('darkModeToggle');
      icon.classList.toggle('fa-moon');
      icon.classList.toggle('fa-sun');
      
      appState.settings.darkMode = document.body.classList.contains('dark-mode');
      saveData();
    }

    function searchCustomers() {
      updateCustomerList();
    }

    function searchHistory() {
      updateAllTransactions();
    }

    function shareOnWhatsApp() {
      const customerId = document.getElementById('customerDetailModal').getAttribute('data-customer-id');
      const customer = appState.customers.find(c => c.id === customerId);
      
      if (!customer) return;
      
      const transactions = appState.transactions
        .filter(t => t.customerId === customerId)
        .sort((a, b) => new Date(b.date) - new Date(a.date));
      
      let message = `*${customer.name}* का खाता विवरण\n`;
      message += `📞 ${customer.phone || 'नंबर नहीं'}\n`;
      message += `💰 बैलेंस: ₹${Math.abs(customer.balance)} ${customer.balance >= 0 ? '(लेना है)' : '(देना है)'}\n\n`;
      message += `📝 लेन-देन:\n`;
      
      transactions.forEach(t => {
        message += `${formatDate(t.date)}: ${t.type === 'udhar' ? 'उधार दिया' : 'जमा लिया'} ₹${t.amount}`;
        if (t.note) message += ` (${t.note})`;
        message += '\n';
      });
      
      const url = `https://wa.me/?text=${encodeURIComponent(message)}`;
      window.open(url, '_blank');
    }

    function showNotifications() {
      showToast(currentLanguage === 'hi' ? 'कोई नई सूचना नहीं' : 'No new notifications', 'info');
    }

    function showAnalytics() {
      switchTab('reports');
      document.querySelectorAll('.nav-tab')[3].click();
    }

    // ==================== PWA INSTALLATION ====================
    let deferredPrompt;
    const installButton = document.getElementById('installPWA');

    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      installButton.style.display = 'block';
    });

    function installPWA() {
      if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then((choiceResult) => {
          if (choiceResult.outcome === 'accepted') {
            console.log('User accepted the install prompt');
          }
          deferredPrompt = null;
          installButton.style.display = 'none';
        });
      }
    }

    window.addEventListener('appinstalled', () => {
      installButton.style.display = 'none';
      showToast(currentLanguage === 'hi' ? 'ऐप इंस्टॉल हो गया!' : 'App installed!');
    });


    // ==================== INITIALIZATION ====================
    document.addEventListener('DOMContentLoaded', () => {
      loadData();
      
      // Set up event listeners
      document.getElementById('reportMonth').addEventListener('change', updateReports);
      document.getElementById('reportYear').addEventListener('change', updateReports);
      
      // Close modals when clicking outside
      window.addEventListener('click', (e) => {
        if (e.target.classList.contains('modal')) {
          e.target.classList.remove('active');
        }
      });
      
      // Check for dark mode preference
      if (appState.settings.darkMode) {
        document.body.classList.add('dark-mode');
        document.getElementById('darkModeToggle').classList.replace('fa-moon', 'fa-sun');
      }
      
      // Add APK generation button
      addAPKButton();
      
      // Register service worker for PWA
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('sw.js').catch(err => {
          console.log('Service worker registration failed:', err);
        });
      }
    });
  </script>

